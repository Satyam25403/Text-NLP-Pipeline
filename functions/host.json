{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    },
    "logLevel": {
      "default": "Information",
      "Host.Results": "Error",
      "Function": "Information",
      "Host.Aggregator": "Trace"
    }
  },
  "extensions": {
    "queues": {
      "batchSize": 10,
      "maxDequeueCount": 5,
      "newBatchThreshold": 5,
      "visibilityTimeout": "00:05:00"
    }
  },
  "functionTimeout": "00:10:00"
}